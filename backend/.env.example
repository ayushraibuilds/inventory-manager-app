# ──────────────────────────────────────────────
# ONDC Super Seller — Backend Environment
# ──────────────────────────────────────────────
# Copy this file: cp .env.example .env
# Variables marked [REQUIRED] must be set before starting.
# Variables marked [OPTIONAL] have sensible defaults.

# ── Runtime Mode ──
# Set to "production" to enforce security checks (JWT secret, Twilio sig, etc.)
NODE_ENV="development"                          # [OPTIONAL] development | production

# ── LLM Configuration ──
GROQ_API_KEY="your-groq-api-key"                # [REQUIRED] Get from https://console.groq.com
LLM_MODEL="llama-3.3-70b-versatile"             # [OPTIONAL]

# ── API Authentication ──
API_KEY=""                                       # [OPTIONAL] Leave blank for JWT-only auth

# ── Twilio WhatsApp ──
TWILIO_ACCOUNT_SID=""                            # [REQUIRED for WhatsApp] https://console.twilio.com
TWILIO_AUTH_TOKEN=""                             # [REQUIRED for WhatsApp]
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"     # [OPTIONAL] Sandbox default

# ── JWT Auth ──
# IMPORTANT: Change this to a strong random string in production!
# In production mode, the server will refuse to start with the default value.
JWT_SECRET="super-secret-demo-jwt-key-change-me" # [REQUIRED in production]

# ── Supabase ──
SUPABASE_URL="https://your-project.supabase.co"  # [REQUIRED] Project URL
SUPABASE_ANON_KEY="your-anon-key"                # [REQUIRED] anon/public key
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key" # [REQUIRED] service_role key

# ── Redis (for Celery background tasks) ──
REDIS_URL="redis://localhost:6379/0"             # [OPTIONAL] Default for local dev

# ── CORS ──
CORS_ORIGINS="http://localhost:3000,http://localhost:3001" # [OPTIONAL] comma-separated

# ── Observability (Optional) ──
# SENTRY_DSN=""                                  # [OPTIONAL] Sentry error tracking DSN
# LOG_LEVEL="INFO"                               # [OPTIONAL] DEBUG | INFO | WARNING | ERROR
