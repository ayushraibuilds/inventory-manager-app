# ONDC Super Seller - Production Environment Template
# Copy only the variables relevant to each deployed service.

# Backend / Railway web service
NODE_ENV=production
PUBLIC_URL=https://your-backend.up.railway.app
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
GROQ_API_KEY=your-groq-api-key
JWT_SECRET=replace-with-a-long-random-secret
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
REDIS_URL=redis://default:password@host:6379/0
CORS_ORIGINS=https://your-dashboard.vercel.app

# Optional backend variables
API_KEY=
SENTRY_DSN=
LLM_MODEL=llama-3.3-70b-versatile
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Dashboard / Vercel
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app

# Optional dashboard variable if you expose API key auth in the dashboard
NEXT_PUBLIC_API_KEY=
